rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidSession(data, userId) {
      return data.userId == userId &&
             data.challengeLevel is string && data.challengeLevel.size() < 50 &&
             data.intention is string && data.intention.size() < 1000 &&
             data.activityType is string && data.activityType.size() < 50 &&
             data.helpType is string && data.helpType.size() < 50 &&
             data.urgency is string && data.urgency.size() < 50 &&
             (!('debriefContent' in data) || (data.debriefContent is string && data.debriefContent.size() < 10000)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                    hasRequiredFields(['userId', 'challengeLevel', 'intention', 'activityType', 'helpType', 'urgency', 'createdAt']) &&
                    isValidSession(request.resource.data, userId);
      allow update: if isOwner(userId) && 
                    isValidSession(request.resource.data, userId) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
