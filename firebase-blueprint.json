{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "A psychotherapy session configuration and brief",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this session"
        },
        "challengeLevel": {
          "type": "string"
        },
        "intention": {
          "type": "string"
        },
        "activityType": {
          "type": "string"
        },
        "helpType": {
          "type": "string"
        },
        "urgency": {
          "type": "string"
        },
        "debriefContent": {
          "type": "string"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "challengeLevel", "intention", "activityType", "helpType", "urgency", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Sessions belonging to a user"
    }
  }
}
